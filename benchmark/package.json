{
  "name": "bench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ scripts/",
    "format": "biome format src/ scripts/ --write",
    "check": "bun run typecheck && bun run lint",
    "knip": "knip --config knip.config.ts",
    "test": "bun test",
    "ci": "bun run typecheck && bun run lint && bun run knip && bun test"
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "knip": "^6.12.2",
    "typescript": "^5.8.3"
  }
}
