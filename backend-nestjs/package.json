{
  "name": "backend-nestjs",
  "version": "0.5.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpx @nestjs/cli build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "seed": "npx ts-node src/seed.ts",
    "migration:generate": "npx typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:run": "npx typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check": "tsc --noEmit",
    "knip": "knip --config config/knip.json",
    "depcruise": "depcruise --config config/.dependency-cruiser.cjs src",
    "test": "vitest run --config config/vitest.unit.config.ts && vitest run --config config/vitest.it.config.ts",
    "test:unit": "vitest run --config config/vitest.unit.config.ts",
    "test:it": "vitest run --config config/vitest.it.config.ts",
    "test:watch": "vitest --config config/vitest.unit.config.ts",
    "test:coverage": "vitest run --config config/vitest.unit.config.ts --coverage && vitest run --config config/vitest.it.config.ts --coverage",
    "test:debug": "vitest --config config/vitest.unit.config.ts --inspect-brk"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "@scalar/nestjs-api-reference": "^1.1.16",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "axios": "^1.16.1",
    "better-auth": "^1.6.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.29"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "knip": "^6.14.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.14.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.6"
  }
}
