    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "shadcn": "^4.7.0",
