#!/bin/sh
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  BLOCKED: Direct push to main is not allowed.          ║"
    echo "║  Create a PR instead: gh pr create                     ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
  fi
done
